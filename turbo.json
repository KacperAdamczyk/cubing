{
	"$schema": "https://turborepo.com/schema.json",
	"tasks": {
		"build": {
			"outputs": ["dist/**", ".svelte-kit/**", "build/**"],
			"dependsOn": ["^build"]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": ["^build"]
		},
		"lint": {},
		"format:check": {},
		"format:write": {},
		"test": {
			"outputs": ["coverage/**"],
			"dependsOn": ["^build"]
		},
		"test:ui": {
			"cache": false,
			"persistent": true
		},
		"check": {
			"dependsOn": ["^build"]
		},
		"preview": {
			"cache": false,
			"persistent": true
		}
	}
}
